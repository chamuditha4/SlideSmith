{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "env": {
    "SLIDESMITH_DIR": "/tmp/slidesmith"
  },
  "functions": {
    "api/index.js":           { "maxDuration": 60  },
    "api/library/scrape.js":  { "maxDuration": 300 }
  },
  "rewrites": [
    { "source": "/api/library/scrape", "destination": "/api/library/scrape" },
    { "source": "/api/(.*)",           "destination": "/api/index"           },
    { "source": "/((?!api/).*)",       "destination": "/index.html"          }
  ]
}
