{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "env": {
    "SLIDESMITH_DIR": "/tmp/slidesmith"
  },
  "functions": {
    "api/index.js": { "maxDuration": 300 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
